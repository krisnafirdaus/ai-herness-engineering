# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in only what you need. EVERYTHING here is optional:
# with an empty .env the harness runs fully offline using the deterministic
# `mock` LLM provider, the local sandbox, and a SQLite state store.
# ─────────────────────────────────────────────────────────────────────────────

# ── Orchestration engine ─────────────────────────────────────────────────────
# One of: auto | langgraph | builtin
#   auto -> LangGraph StateGraph when the package is installed, else the
#           dependency-free builtin driver. Both share identical persistence
#           and resume semantics (see docs/adr/0001).
HARNESS_ORCHESTRATOR=auto

# ── LLM provider ─────────────────────────────────────────────────────────────
# One of: mock | anthropic | openai
HARNESS_LLM_PROVIDER=mock
# Used when provider != mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Model id (provider-specific). Sensible defaults are applied if unset.
HARNESS_LLM_MODEL=

# ── Sandbox ──────────────────────────────────────────────────────────────────
# One of: auto | docker | k8s | local
#   auto -> Docker if a daemon is reachable, else local — but remote-URL repos
#           are UNTRUSTED and refuse the local fallback (fail closed) unless
#           HARNESS_ALLOW_LOCAL_UNTRUSTED=1.
HARNESS_SANDBOX=auto
# Image used for the Docker/k8s sandbox (python3 + node for the dummy repos)
HARNESS_SANDBOX_IMAGE=harness-sandbox:latest
# Explicit opt-in to run untrusted (remote) repos in the non-isolating local
# sandbox. Leave unset in anything resembling production.
HARNESS_ALLOW_LOCAL_UNTRUSTED=
# Optional `ulimit -u` for local sandbox commands (0/unset = leave alone)
HARNESS_LOCAL_NPROC=

# ── Kubernetes sandbox (HARNESS_SANDBOX=k8s) ─────────────────────────────────
HARNESS_K8S_NAMESPACE=default
# Set to gvisor (with infra/k8s/runtimeclass-gvisor.yaml applied) for a
# user-space-kernel boundary around sandbox pods.
HARNESS_K8S_RUNTIME_CLASS=
HARNESS_K8S_POD_STARTUP_SEC=120

# ── GitHub PR creation ───────────────────────────────────────────────────────
# Token with `repo` scope; HARNESS_GITHUB_TOKEN wins over GITHUB_TOKEN.
GITHUB_TOKEN=
HARNESS_GITHUB_TOKEN=
# Auto-open a PR when a GitHub-hosted run completes (default on; needs token).
HARNESS_AUTO_PR=1
# Override for GitHub Enterprise.
HARNESS_GITHUB_API_URL=https://api.github.com

# ── State store ──────────────────────────────────────────────────────────────
# sqlite:///absolute/path.sqlite3   (default)   OR   postgresql://user:pass@host/db
HARNESS_DATABASE_URL=sqlite:///./harness.sqlite3

# ── Queue (for the API server + worker pool) ─────────────────────────────────
# One of: db | redis     (db = poll the state store; redis = production queue)
HARNESS_QUEUE=db
HARNESS_REDIS_URL=redis://localhost:6379/0

# ── Event streaming (SSE/WebSocket push) ─────────────────────────────────────
# One of: auto | memory | redis
#   auto -> redis pub/sub when HARNESS_QUEUE=redis (separate workers), else
#           in-process fan-out. The events table is always the durable log.
HARNESS_EVENT_BUS=auto

# ── Cost / safety guardrails ─────────────────────────────────────────────────
HARNESS_MAX_RETRIES=3              # max executor/verifier fix iterations per step
HARNESS_MAX_TOKENS_PER_RUN=200000  # hard token budget; run FAILs if exceeded
HARNESS_STEP_TIMEOUT_SEC=600       # wall-clock timeout per verification command

# ── Retention / cleanup ──────────────────────────────────────────────────────
HARNESS_WORKSPACE_TTL_HOURS=72     # delete terminal-run workspaces after this
HARNESS_RUN_RETENTION_DAYS=30      # purge runs+steps+traces+events after this
HARNESS_SWEEP_INTERVAL_SEC=3600    # how often each worker runs the sweep

# ── Telemetry (optional Langfuse export; spans are always stored in the DB) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
